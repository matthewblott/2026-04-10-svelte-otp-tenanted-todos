{
	"name": "todos",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate":        "drizzle-kit generate --config=./config/drizzle.shared.config.ts && drizzle-kit generate --config=./config/drizzle.app.config.ts",
    "db:push:shared":     "drizzle-kit push --config=./config/drizzle.shared.config.ts",
    "db:push:app":        "drizzle-kit push --config=./config/drizzle.app.config.ts",
    "db:push":            "bun run db:push:shared && bun run db:push:app",
    "db:migrate:shared":  "drizzle-kit migrate --config=./config/drizzle.shared.config.ts",
    "db:studio:shared":   "drizzle-kit studio --config=./config/drizzle.shared.config.ts",
    "db:studio:app":      "drizzle-kit studio --config=./config/drizzle.app.config.ts",
    "db:seed":            "tsx scripts/seed.ts",
    "db:reset":           "rm -f storage/shared.db storage/template.db storage/data/*.db && bun run db:push && bun run db:seed"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/nodemailer": "^7.0.11",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"better-sqlite3": "^12.8.0",
		"drizzle-orm": "^0.45.2",
		"nodemailer": "^8.0.4",
		"valibot": "^1.3.1"
	}
}
